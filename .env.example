# ==========================================
# LLM API 配置文件
# ==========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据你使用的LLM服务取消注释相应配置
# 3. 填写正确的API密钥和模型名称
# ==========================================

# ==========================================
# 选项1: LM Studio 本地模型（推荐用于学习）
# ==========================================
# 启动LM Studio后，确保：
# 1. 已下载并加载模型
# 2. 开启了本地服务器（Local Server）
# 3. 端口为1234（默认）
OPENAI_API_KEY=lm-studio
API_BASE_URL=http://localhost:1234/v1
MODEL_NAME=qwen3.5-9b

# ==========================================
# 选项2: Ollama 本地模型
# ==========================================
# 启动Ollama后，确保：
# 1. 已拉取模型（如 ollama pull llama2）
# 2. Ollama服务正在运行
# OPENAI_API_KEY=ollama
# API_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama2

# ==========================================
# 选项3: OpenAI 官方API
# ==========================================
# 从 https://platform.openai.com/api-keys 获取API密钥
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-3.5-turbo

# ==========================================
# 选项4: 其他兼容OpenAI API的服务
# ==========================================
# 如 OneAPI、NewAPI、DeepSeek 等
# OPENAI_API_KEY=your-api-key
# API_BASE_URL=https://your-api-server.com/v1
# MODEL_NAME=gpt-3.5-turbo
